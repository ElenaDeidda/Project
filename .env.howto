# ══════════════════════════════════════════════════════════════
# Configurazione agenti Deliveroo — Challenge 2 (BDI + LLM)
# ══════════════════════════════════════════════════════════════

# ── Connessione al gioco ──────────────────────────────────────
HOST=https://deliveroojs.bears.disi.unitn.it/
TOKEN=il_tuo_token_qui

# ── Team (per la comunicazione BDI ↔ LLM) ─────────────────────
# TEAM_ID non serve più: viene preso direttamente dal token JWT lato server
# e letto via onYou (beliefs.me.teamId). Assicurati solo che i due agenti
# usino token associati allo stesso team.
# Ruolo di QUESTO processo: 'bdi' oppure 'llm'
ROLE=bdi

# ── PDDL planner (parte 1) ────────────────────────────────────
# true  → usa il planner PDDL (mappe piccole/semplici)
# false → usa sempre A* (default robusto)
USE_PDDL=false

# ── LLM (parte 2) — LiteLLM UniTN, come nel lab8 ──────────────
LITELLM_BASE_URL=https://llm.bears.disi.unitn.it/v1
LITELLM_API_KEY=la_tua_api_key_qui
LOCAL_MODEL=llama-3.3-70b-lmstudio
