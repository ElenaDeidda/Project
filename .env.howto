# ══════════════════════════════════════════════════════════════
# Configurazione agenti Deliveroo — Challenge 2 (BDI + LLM)
# ══════════════════════════════════════════════════════════════
#
# OPZIONE 1 (rapida): un solo file `.env` letto sia da main.js che da llm_main.js.
#   Usa lo stesso TOKEN per entrambi i processi → diventano lo stesso agente
#   (rischiano di confondersi). Va bene per test rapidi di un solo agente.
#
# OPZIONE 2 (consigliata): due file separati, uno per ogni processo.
#   - `.env.bdi`  letto da `main.js`      (TOKEN dell'agente BDI)
#   - `.env.llm`  letto da `llm_main.js`  (TOKEN dell'agente LLM, key LiteLLM)
#   Se .env.bdi / .env.llm non esistono, gli script ripiegano su .env.
#
# Variabili — non tutte servono ad entrambi i processi:
# ──────────────────────────────────────────────────────────────

# ── Connessione al gioco (entrambi) ───────────────────────────
HOST=http://localhost:8080

# ── Token (DIVERSO per BDI e LLM se vuoi due agenti reali) ────
TOKEN=il_tuo_token_qui

# ── Team: non serve più impostarlo. Viene letto dal JWT lato server
#    (campo teamId) e finisce in beliefs.me.teamId via onYou.

# ── Ruolo del processo (informativo, usato dai log) ───────────
ROLE=bdi          # in .env.bdi
# ROLE=llm        # in .env.llm

# ── PDDL planner (solo BDI) ───────────────────────────────────
# true  → usa il planner PDDL; false → A* sempre
USE_PDDL=false

# ── LLM (solo .env.llm) — LiteLLM UniTN, come lab8 ────────────
LITELLM_BASE_URL=https://llm.bears.disi.unitn.it/v1
LITELLM_API_KEY=la_tua_api_key_qui
LOCAL_MODEL=llama-3.3-70b-lmstudio
# Temperatura del modello (0 = deterministico, 0.2 default, 0.5 più creativo)
LLM_TEMP=0.2
